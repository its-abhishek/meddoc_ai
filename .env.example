# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/meddocs
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5433/meddocs

# Redis
REDIS_URL=redis://localhost:6379/0

# Groq LLM (get free key at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_REASONING_MODEL=llama-3.1-8b-instant
GROQ_CLASSIFICATION_MODEL=llama-3.1-8b-instant

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Storage
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=20

# Frontend (set in Render dashboard)
# NEXT_PUBLIC_API_URL=https://meddocs-api.onrender.com
# NEXT_PUBLIC_MONITOR_URL=https://meddocs-api.onrender.com
